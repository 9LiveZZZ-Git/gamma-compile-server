{
  "name": "@9livezzz/gamma-compile-server",
  "version": "0.3.8",
  "description": "Local Emscripten compile daemon + OSC bridge for the Gamma Node Editor. Runs on localhost:8765 by default and listens for OSC on udp://localhost:9000; --host/--allowOrigin let it serve a LAN setup (e.g. iPad → Mac).",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "gamma-compile-server": "bin/gamma-compile-server.js"
  },
  "scripts": {
    "start": "node bin/gamma-compile-server.js",
    "test": "node tests/smoke.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ws": "^8.20.1"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gamma",
    "emscripten",
    "wasm",
    "audio",
    "dsp",
    "compile-server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/9LiveZZZ-Git/gamma-compile-server"
  }
}
